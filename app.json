{
  "expo": {
    "name": "map.play",
    "slug": "map.play",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "mapplay",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#E6F4FE"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mapplay.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.mapplay.app"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-osm-sdk",
        {
          "locationWhenInUseDescription": "Used to show your position on the map and find nearby players."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow map.play to use your location to center the map on your position.",
          "locationAlwaysPermission": "Allow map.play to use your location in the background.",
          "locationWhenInUsePermission": "Allow map.play to use your location to center the map."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
